// Get current language from localStorage or default to 'en'
function getCurrentLanguage() {
    return localStorage.getItem('preferredLang') || 'en';
}

// Set language and save to localStorage
function setLanguage(lang) {
    localStorage.setItem('preferredLang', lang);
    // Reload page to apply language changes
    location.reload();
}

// Get translations for current language
function getTranslations() {
    const lang = getCurrentLanguage();
    return TRANSLATIONS[lang] || TRANSLATIONS['en'];
}

// Apply translations to page elements
function applyTranslations(lang) {
    const dict = TRANSLATIONS[lang] || TRANSLATIONS['en'];

    // Update welcome title and subtitle
    const welcomeTitle = document.querySelector('#welcome-title');
    if (welcomeTitle) welcomeTitle.textContent = dict.welcome;
    
    const subtitle = document.querySelector('.subtitle');
    if (subtitle) subtitle.textContent = dict.subtitle;

    // Update navbar links using data-key attribute
    const navElements = {
        'appointments': document.querySelector('[data-key="appointments"]'),
        'departments': document.querySelector('[data-key="departments"]'),
        'pharmacy': document.querySelector('[data-key="pharmacy"]'),
        'lab': document.querySelector('[data-key="lab"]'),
        'billing': document.querySelector('[data-key="billing"]'),
        'chatbot': document.querySelector('[data-key="chatbot"]'),
        'emergency': document.querySelector('[data-key="emergency"]'),
        'logout': document.querySelector('[data-key="logout"]')
    };
    
    Object.keys(navElements).forEach(key => {
        if (navElements[key]) navElements[key].textContent = dict[key];
    });

    // Update department cards
    document.querySelectorAll('.card[data-key]').forEach(card => {
        const key = card.dataset.key.toLowerCase();
        const titleEl = card.querySelector('strong');
        const descEl = card.querySelector('.card-details');
        
        if (titleEl && dict[key]) {
            titleEl.textContent = dict[key];
        }
        const descKey = key + '_desc';
        if (descEl && dict[descKey]) {
            descEl.textContent = dict[descKey];
        }
    });
}

// Update language button display
function updateLangButton(lang) {
    const names = {
        en: { flag: "🇬🇧", name: "English" },
        hi: { flag: "🇮🇳", name: "हिन्दी" },
        ta: { flag: "🇮🇳", name: "தமிழ்" },
        te: { flag: "🇮🇳", name: "తెలుగు" },
        kn: { flag: "🇮🇳", name: "ಕನ್ನಡ" }
    };
    const info = names[lang] || names.en;
    const flagEl = document.getElementById('lang-flag');
    const nameEl = document.getElementById('lang-name');
    if (flagEl) flagEl.textContent = info.flag;
    if (nameEl) nameEl.textContent = info.name;
}

// Initialize language on page load
function initLanguage() {
    const currentLang = getCurrentLanguage();
    applyTranslations(currentLang);
    updateLangButton(currentLang);
    
    // Setup language dropdown listeners
    document.querySelectorAll('.lang-dropdown a').forEach(item => {
        item.addEventListener('click', (e) => {
            e.preventDefault();
            const lang = item.dataset.lang;
            setLanguage(lang);
        });
    });
}

// Auto-initialize when DOM is ready
document.addEventListener('DOMContentLoaded', initLanguage);
